# ============================================================
# 项目环境变量配置示例
# 复制此文件为 .env 并填写你的本地路径
# ============================================================

# 项目根目录（必填）
PROJECT_ROOT=/path/to/your/thesis-project

# Qdrant 向量数据库路径（可选，默认: $PROJECT_ROOT/qdrant_data）
QDRANT_PATH=

# 参考文献目录（可选）
REF_DIR=

# 论文 docx 文件路径（用于格式检查脚本）
THESIS_PATH=./thesis.docx

# 输出目录（用于改写/导出脚本）
OUTPUT_DIR=./output

# Vault 数据库路径（用于混合检索）
VAULT_DB_PATH=

# ANSYS/Fluent 相关（用于自动化脚本）
AWP_ROOT242=C:\Program Files\ANSYS Inc\v242
CASE_NAME=test_case
WORK_DIR=./output
